# Environment variables for Pocket Booth

# ======================================================================
# Key-Based Photo Limit Configuration
# ======================================================================
# This allows you to pre-configure photo limits that are loaded via URL
# Usage: Add ?key=YOUR_KEY to the URL
# Example: https://yourapp.com/?key=myevent
#
# Format: VITE_CONFIG_[KEY_NAME]=[photoLimit]
# The key is stored in sessionStorage and persists for the session
# - photoLimit: Maximum number of photo strips allowed (leave empty for unlimited)

# Example configurations:
# VITE_CONFIG_MYEVENT=10
# VITE_CONFIG_WEDDING=5
# VITE_CONFIG_BIRTHDAY=20
# VITE_CONFIG_DEMO=3
# VITE_CONFIG_UNLIMITED=

# ======================================================================
# Google Drive Upload Configuration (Google Apps Script)
# ======================================================================

# *** MULTI-ACCOUNT SUPPORT ***
# Each key can upload to a different Google account by pointing it at a
# different Apps Script Web App deployment. See apps-script/Code.gs for
# the script to deploy, and GOOGLE_DRIVE_SETUP.md for full setup steps.

# Format: VITE_APPS_SCRIPT_URL_{KEY_NAME}={deployment_url}
# The deployment URL looks like:
#   https://script.google.com/macros/s/XXXXXXXXXXXX/exec
#
# Leave empty (or omit) to disable uploads for that key — photos will
# still be downloadable locally.

# VITE_APPS_SCRIPT_URL_WEDDING=
# VITE_APPS_SCRIPT_URL_BIRTHDAY=

# Note: Photos are always stored locally in the browser's localStorage.
# Apps Script upload is an optional addition, not a replacement.

VITE_CONFIG_KEY=3
VITE_APPS_SCRIPT_URL_KEY=<url_to_your_apps_script_deployment>